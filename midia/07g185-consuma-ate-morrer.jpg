		}
	.sidebar:not(.widget-minimal) .widget_block .wp-block-group__inner-container .widget-title {
		position: relative;
		padding-bottom: 10px;
	}
	.sidebar:not(.widget-minimal) .widget_block .wp-block-group__inner-container .widget-title:after {
		content: '';
